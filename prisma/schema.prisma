generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  DEVELOPER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  googleId     String?  @unique
  passwordHash String
  name         String?
  profileImage String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}