generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  DEVELOPER
  ADMIN
}

enum CreditKind {
  FREE
  PAID
}

enum CreditGrantStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  CANCELLED
}

enum CreditTransactionType {
  PURCHASE
  USAGE
  REFUND
  ADJUSTMENT
  PROMOTION
  EXPIRATION
}

enum CreditTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  PORTONE
}

enum PaymentOrderStatus {
  PENDING
  CHECKOUT_CREATED
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum MusicStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum VideoStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobTargetType {
  MUSIC
  VIDEO
}

enum JobType {
  MUSIC_GENERATION
  MUSIC_STATUS_POLL
  VIDEO_RENDER
}

enum QueueStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum AssetStatus {
  PENDING
  READY
  FAILED
  DELETED
}

enum MusicAssetType {
  MP3
  COVER_IMAGE
  ALIGNED_LYRICS_RAW_JSON
  ALIGNED_LYRICS_LINES_JSON
  TITLE_TEXT
}

enum AssetStorageTier {
  HOT
  ARCHIVE
}

enum InboundEmailStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  googleId     String?  @unique
  passwordHash String
  freeCredits  Int      @default(0)
  paidCredits  Int      @default(0)
  tier         String?
  name         String?
  profileImage String?
  role         UserRole @default(USER)
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  musics         Music[]
  musicLikes     MusicLike[]
  generationJobs GenerationJob[]
  creditGrants   CreditGrant[]
  creditTransactions CreditTransaction[]
  paymentOrders  PaymentOrder[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model InboundEmail {
  id         String             @id @default(cuid())
  messageId  String?            @unique
  fromEmail  String
  fromName   String?
  toEmail    String
  subject    String?
  textBody   String?
  htmlBody   String?
  receivedAt DateTime           @default(now())
  status     InboundEmailStatus @default(NEW)
  rawPayload Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  attachments InboundEmailAttachment[]

  @@index([status, receivedAt])
  @@index([receivedAt])
}

model InboundEmailAttachment {
  id             String   @id @default(cuid())
  inboundEmailId String
  filename       String
  contentType    String?
  size           Int?
  storagePath    String?
  createdAt      DateTime @default(now())

  inboundEmail InboundEmail @relation(fields: [inboundEmailId], references: [id], onDelete: Cascade)

  @@index([inboundEmailId, createdAt])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Music {
  id             String      @id @default(cuid())
  userId         String
  requestGroupId String?
  isPublic       Boolean     @default(true)
  title          String?
  lyrics         String
  stylePrompt    String
  isMr           Boolean     @default(false)
  provider       String
  providerTaskId String?    @unique
  mp3Url         String?
  imageUrl       String?
  videoUrl       String?
  rawStatus      String?
  rawPayload     Json?
  rawResponse    Json?
  isBonusTrack   Boolean     @default(false)
  bonusUnlockedAt DateTime?
  status         MusicStatus @default(QUEUED)
  duration       Int?
  tags           String?
  errorMessage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets         MusicAsset[]
  videos         Video[]
  likes          MusicLike[]
  generationJobs GenerationJob[]
  creditTransactions CreditTransaction[]

  @@index([userId, createdAt])
  @@index([requestGroupId, createdAt])
  @@index([status])
  @@index([isPublic, createdAt])
}

model MusicLike {
  id        String   @id @default(cuid())
  musicId    String
  userId     String
  createdAt  DateTime @default(now())

  music Music @relation(fields: [musicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([musicId, userId])
  @@index([musicId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model CreditGrant {
  id              String            @id @default(cuid())
  userId          String
  creditKind      CreditKind
  amount          Int
  remainingAmount Int
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  status          CreditGrantStatus @default(ACTIVE)
  source          String?
  paymentOrderId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)

  @@index([userId, creditKind, status])
  @@index([expiresAt, status])
  @@index([paymentOrderId])
}

model CreditTransaction {
  id             String                  @id @default(cuid())
  userId         String
  musicId        String?
  videoId        String?
  paymentOrderId String?
  amount         Int
  creditKind     CreditKind?
  type           CreditTransactionType
  status         CreditTransactionStatus @default(COMPLETED)
  balanceAfter   Int
  memo           String?
  metadata       Json?
  createdAt      DateTime                @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  music        Music?        @relation(fields: [musicId], references: [id], onDelete: SetNull)
  video        Video?        @relation(fields: [videoId], references: [id], onDelete: SetNull)
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, status])
  @@index([musicId])
  @@index([videoId])
  @@index([paymentOrderId])
}

model PaymentOrder {
  id                    String             @id @default(cuid())
  userId                String
  provider              PaymentProvider
  status                PaymentOrderStatus @default(PENDING)
  productCode           String
  requestedCredits      Int
  amount                Int
  currency              String             @default("KRW")
  stripeSessionId       String?            @unique
  stripePaymentIntentId String?            @unique
  stripeCustomerId      String?
  externalOrderId       String             @unique
  paidAt                DateTime?
  refundedAt            DateTime?
  rawPayload            Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditGrants       CreditGrant[]
  creditTransactions CreditTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([provider, status])
}

model MusicAsset {
  id            String           @id @default(cuid())
  musicId       String
  assetType     MusicAssetType
  status        AssetStatus      @default(PENDING)
  storageTier   AssetStorageTier @default(HOT)
  sourceUrl     String?
  storageKey    String?
  storagePath   String?
  publicUrl     String?
  mimeType      String?
  fileSize      Int?
  checksum      String?
  archivedAt    DateTime?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  music         Music            @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@unique([musicId, assetType])
  @@index([musicId, status])
  @@index([assetType, status])
  @@index([storageTier, updatedAt])
  @@index([storageKey])
}

model Video {
  id             String          @id @default(cuid())
  musicId        String
  mp4Url         String?
  bgImageUrl     String?
  srtUrl         String?
  status         VideoStatus     @default(QUEUED)
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  music          Music           @relation(fields: [musicId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]
  creditTransactions CreditTransaction[]

  @@index([musicId, createdAt])
  @@index([status])
}

model GenerationJob {
  id           String        @id @default(cuid())
  userId       String
  musicId      String?
  videoId      String?
  targetType   JobTargetType
  jobType      JobType
  queueStatus  QueueStatus   @default(QUEUED)
  priority     Int           @default(100)
  attemptCount Int           @default(0)
  maxAttempts  Int           @default(3)
  runAfter     DateTime      @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  lockedAt     DateTime?
  lockedBy     String?
  lastCheckedAt DateTime?
  providerTaskId String?
  payload      Json?
  result       Json?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  music Music? @relation(fields: [musicId], references: [id], onDelete: Cascade)
  video Video? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([queueStatus, jobType])
  @@index([queueStatus, runAfter, priority])
  @@index([musicId])
  @@index([videoId])
  @@index([providerTaskId])
}


