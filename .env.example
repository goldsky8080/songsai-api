# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
BROWSER_MANUAL_CAPTCHA=false # true to keep the browser open and wait for manual CAPTCHA solving
BROWSER_MANUAL_CAPTCHA_TIMEOUT_MS=300000 # 5 minutes
BROWSER_PROFILE_DIR= # Optional persistent browser profile directory, e.g. /home/young/.config/google-chrome

